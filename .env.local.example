# Configuration Dolibarr API
NEXT_PUBLIC_DOLIBARR_URL=http://votre-dolibarr.com
NEXT_PUBLIC_DOLIBARR_API_KEY=votre_cle_api_dolibarr

# Secret de session (obligatoire en production)
AUTH_SECRET=change-moi-en-production

# Configuration Application
NEXT_PUBLIC_APP_NAME=Atelier Informatique
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Configuration SMTP (notifications e-mail automatiques)
SMTP_HOST=smtp.votre-fournisseur.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-utilisateur-smtp
SMTP_PASS=votre-mot-de-passe-smtp
# Adresse expediteur (le nom affiche vient automatiquement de NEXT_PUBLIC_APP_NAME)
SMTP_FROM=no-reply@votredomaine.fr

# Configuration Base de Données
DATABASE_URL="file:./prisma/dev.db"
